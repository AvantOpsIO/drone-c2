#!/bin/sh
# shellcheck disable=SC2154

#param set-default MAV_SYS_ID $((px4_instance+1))
#param set-default IMU_INTEG_RATE 250

# Docker fleet: unique MAV_SYS_ID from DRONE_INDEX (set by compose / up-fleet.sh).
if [ -n "${DRONE_INDEX}" ]; then
  echo "[px4-docker] DRONE_INDEX=${DRONE_INDEX} -> param set MAV_SYS_ID"
  param set MAV_SYS_ID "${DRONE_INDEX}"
fi
